# AI Provider Selection
# Options: cloudflare (default), groq, anthropic
AI_PROVIDER=cloudflare

# Cloudflare Workers AI (FREE tier included)
# 1. Go to https://dash.cloudflare.com/
# 2. Get your Account ID from the right sidebar on any page
# 3. Create API Token: My Profile > API Tokens > Create Token > "Edit Cloudflare Workers" template
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Optional: Cloudflare model tier mode
# tier1 = cheapest/default, tier2 = stronger, tier3 = alternate model, auto = try tier1->tier2->tier3
CF_TIER_MODE=tier1
CF_TIER1_MODEL=@cf/meta/llama-3.1-8b-instruct
CF_TIER2_MODEL=@cf/meta/llama-3.1-70b-instruct
CF_TIER3_MODEL=@cf/mistral/mistral-7b-instruct-v0.2

# Alternative: Groq API (FREE - 14,400 requests/day)
# Get your key from: https://console.groq.com/
# GROQ_API_KEY=gsk_...

# Alternative: Anthropic Claude (Paid)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
